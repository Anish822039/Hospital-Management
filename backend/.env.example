# ============================================================
# HMS Environment Configuration  —  NEVER commit this file
# ============================================================

# Server
NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_root_password
DB_NAME=hms_db

# JWT
JWT_SECRET=ef32f6d40360ce797e7705e25c0350767191b21e6e87f0860f7a2b94236f5a3e
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=replace_with_another_64_char_secret
JWT_REFRESH_EXPIRES_IN=7d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Hospital Info (used in invoices/reports)
HOSPITAL_NAME=City General Hospital
HOSPITAL_ADDRESS=123 Medical Drive, Healthcare City
HOSPITAL_PHONE=+91-000-000-0000
HOSPITAL_EMAIL=info@citygeneralhospital.com
